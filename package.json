name: Build and Push

on:
  push:
    branches: [ main ]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      
      - name: Clean and create correct package.json
        run: |
          rm -f package.json
          echo '{
            "name": "kanban-backend",
            "version": "1.0.0",
            "main": "server.js",
            "scripts": {
              "start": "node server.js"
            }
          }' > package.json
      
      - name: Login to Docker Hub
        uses: docker/login-action@v2
        with:
          username: ${{ secrets.NAME }}
          password: ${{ secrets.PASSWORD }}
      
      - name: Build and push
        run: |
          docker build -t ${{ secrets.NAME }}/kanban-backend:latest .
          docker push ${{ secrets.RNAME }}/kanban-backend:latest
