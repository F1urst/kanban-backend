name: Build and Push

on:
  push:
    branches: [ main ]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      
      - name: Find package.json
        run: |
          echo "Поиск package.json:"
          find $(pwd) -name "package.json" -type f
          echo "Содержимое корня:"
          ls -la
          echo "Содержимое всех папок:"
          ls -la */
      
      - name: Login to Docker Hub
        uses: docker/login-action@v2
        with:
          username: ${{ secrets.DOCKER_USERNAME }}
          password: ${{ secrets.DOCKER_PASSWORD }}
      
      - name: Build and push
        run: |
          docker build -t ${{ secrets.DOCKER_USERNAME }}/kanban-backend:latest .
          docker push ${{ secrets.DOCKER_USERNAME }}/kanban-backend:latest
